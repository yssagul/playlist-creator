# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_API_SECRET=your_lastfm_api_secret
LASTFM_USERNAME=your_lastfm_username

# Tidal — https://developer.tidal.com
TIDAL_CLIENT_ID=your_tidal_client_id
TIDAL_CLIENT_SECRET=your_tidal_client_secret

# GetSongBPM — https://getsongbpm.com/api (optional, enables BPM/key sorting)
GETSONGBPM_API_KEY=your_getsongbpm_api_key

# Settings (optional — defaults shown)
STATE_FILE=.playlist_state.json
TIDAL_SESSION_FILE=.tidal_session.json
FAILURE_LOG=transfer_failures.log
